{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "moduleResolution": "node",
    "noImplicitAny": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "client/rollup.config.ts",
    "client/src/**/*.ts",
    "server",
    "scripts"
  ],
  "exclude": ["node_modules"]
}

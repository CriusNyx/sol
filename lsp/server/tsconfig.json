{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "outDir": "out",
    "rootDir": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": ["src", "build.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}

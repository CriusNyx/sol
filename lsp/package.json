{
  "name": "sol-language-server",
  "description": "A language server example",
  "author": "Microsoft Corporation",
  "license": "MIT",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Microsoft/vscode-extension-samples"
  },
  "publisher": "crius-nyx",
  "categories": [],
  "keywords": [
    "multi-root ready"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:plaintext"
  ],
  "main": "./client/out/main",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Sol Language Server",
      "properties": {
        "languageServerExample.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "languageServerExample.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn compile",
    "esbuild-client": "esbuild ./client/src/extension.ts --bundle --outfile=client/out/main.js --external:vscode --format=cjs --platform=node",
    "esbuild-server": "cd server && ts-node build.ts",
    "compile": "yarn build-rust && concurrently \"yarn esbuild-client\" \"yarn esbuild-server\"",
    "preinstall": "yarn build-rust",
    "build-rust": "yarn rust:build-sol-wasm && yarn rust:build-sol-types",
    "rust:build-sol-types": "cd ../sol-js/sol-types && yarn build",
    "rust:build-sol-wasm": "cd ../sol && wasm-pack build --target nodejs --out-dir ../sol-js/node-wasm",
    "watch": "concurrently \"yarn esbuild-client\" \"yarn esbuild-server\"",
    "lint": "eslint",
    "postinstall": "cd client && yarn install && cd ../server && yarn install && cd ..",
    "install-package": "yarn install && vsce package && code --install-extension sol-language-server-1.0.0.vsix",
    "test": "sh ./scripts/e2e.sh"
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@stylistic/eslint-plugin": "4.4.1",
    "@types/mocha": "10.0.10",
    "@types/node": "^24.0.3",
    "concurrently": "^9.1.2",
    "esbuild": "0.25.5",
    "esbuild-plugin-wasm": "^1.1.0",
    "eslint": "9.29.0",
    "mocha": "11.7.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.1"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
